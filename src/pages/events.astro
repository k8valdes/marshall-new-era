---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageBanner from '../components/PageBanner.astro';
import EventCard from '../components/EventCard.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const today = new Date();
today.setHours(0, 0, 0, 0);

const all = (await getCollection('events')).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
);
const upcoming = all.filter((e) => e.data.date >= today);
const past = all.filter((e) => e.data.date < today).reverse();

const shortDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<Base title="Events" description="Board meetings, cleanups, block parties, National Night Out, and the December holiday party — all MNENA events, past and upcoming.">
  <PageBanner title="Events" accent="Get out and meet each other" image={`${base}/illustrations/spot-meeting.svg`} position="center 40%" />

  <section class="section">
    <div class="container events-layout">
      <!-- scannable chronological sidebar -->
      <nav class="events-nav" aria-label="All events, chronological">
        <p class="section-label">Jump to an event</p>
        {upcoming.length > 0 && (
          <>
            <h3 class="nav-group">Upcoming</h3>
            <ul>
              {upcoming.map((e) => (
                <li>
                  <a href={`#${e.id}`}>
                    <span class="nav-date">{shortDate(e.data.date)}</span>
                    <span class="nav-title">{e.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </>
        )}
        <h3 class="nav-group">Past events</h3>
        <ul>
          {past.map((e) => (
            <li>
              <a href={`#${e.id}`}>
                <span class="nav-date">{shortDate(e.data.date)}</span>
                <span class="nav-title">{e.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- full detail list -->
      <div class="events-detail">
        <h2>Coming up</h2>
        <div class="event-list">
          {upcoming.length > 0
            ? upcoming.map((event) => (
                <div class="event-anchor" id={event.id}>
                  <EventCard event={event} full />
                </div>
              ))
            : <p>Nothing on the calendar right now — check back soon or follow us on <a href="https://www.instagram.com/marshallnewera/">Instagram</a>.</p>}
        </div>

        <h2 style="margin-top: var(--space-2xl);">Past events</h2>
        <div class="event-list">
          {past.map((event) => (
            <div class="event-anchor" id={event.id}>
              <EventCard event={event} full />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container narrow">
      <h2>The regulars</h2>
      <dl class="regulars">
        <dt>🗓 Monthly board meetings</dt>
        <dd>
          3rd Monday of each month (except December), 6:00 pm at the Society
          Church building, 2711 B St. Finger-food potluck, City Police and
          agency updates, and everyone is welcome. Agenda requests:
          <a href="mailto:info@marshallnewera.org">info@marshallnewera.org</a>.
        </dd>
        <dt>🧹 Quarterly neighborhood cleanups</dt>
        <dd>
          Every quarter, somewhere in the neighborhood. We start at 8:30 am
          with coffee and bagels, then supply everything you need — gloves,
          pickers, trash bags, and friends.
        </dd>
        <dt>🌭 National Night Out</dt>
        <dd>
          1st Tuesday in August. We join Midtown's other associations for a
          progressive dinner that brings back a true sense of community.
        </dd>
        <dt>🎄 Holiday party</dt>
        <dd>
          A great party in December — potluck, a very small amount of
          "business", and a lot of talking about next year's plans.
        </dd>
      </dl>
    </div>
  </section>
</Base>

<style>
  .events-layout {
    display: grid;
    grid-template-columns: 290px 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }
  @media (max-width: 860px) {
    .events-layout {
      grid-template-columns: 1fr;
    }
    .events-nav {
      position: static;
      max-height: 320px;
    }
  }
  .events-nav {
    position: sticky;
    top: 88px;
    max-height: calc(100vh - 110px);
    overflow-y: auto;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: var(--space-lg);
  }
  .events-nav .nav-group {
    font-size: 1rem;
    margin: var(--space-md) 0 var(--space-xs);
  }
  .events-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .events-nav li a {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: var(--space-sm);
    padding: 0.3rem 0.4rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.3;
  }
  .events-nav li a:hover {
    background: var(--color-background-soft);
  }
  .nav-date {
    color: var(--color-link);
    font-weight: 700;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .nav-title {
    color: var(--color-text-primary);
  }
  .event-list {
    display: grid;
    gap: var(--space-lg);
  }
  .event-anchor {
    scroll-margin-top: 96px; /* clears the sticky header on anchor jumps */
  }
  .event-anchor:target :global(.card) {
    outline: 3px solid var(--color-sun-gold);
  }
  .regulars dt {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-deep-teal);
    margin-top: var(--space-lg);
  }
  .regulars dd {
    margin: var(--space-xs) 0 0;
  }
</style>
