---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import NewsThumb from '../../components/NewsThumb.astro';
import PageBanner from '../../components/PageBanner.astro';
import cityscape from '../../assets/illustrations/cityscape.png';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="News" description="Updates, announcements, and stories from the Marshall–New Era neighborhood.">
  <PageBanner title="Neighborhood news" accent="Hot off the press" image={cityscape} position="right 35%" />
  <section class="section">
    <div class="container narrow">
      <div class="post-list">
        {posts.map((post) => (
          <article class="card news-row">
            <NewsThumb post={post} class="news-row-thumb" />
            <div>
              <p class="section-label">
                {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
              </p>
              <h2 style="font-size: 1.5rem;">
                <a href={`${base}/news/${post.id}/`}>{post.data.title}</a>
              </h2>
              {post.data.excerpt && <p style="margin-bottom: 0;">{post.data.excerpt}</p>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .post-list {
    display: grid;
    gap: var(--space-lg);
  }
  .news-row {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }
  :global(.news-row-thumb) {
    flex: 0 0 280px;
    aspect-ratio: 3 / 2;
  }
  @media (max-width: 640px) {
    .news-row { flex-direction: column; align-items: stretch; }
    :global(.news-row-thumb) { width: 100%; flex-basis: auto; }
  }
</style>
