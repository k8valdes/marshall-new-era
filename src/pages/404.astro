---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import homesBridge from '../assets/illustrations/homes-bridge.png';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Page not found">
  <section class="section">
    <div class="container narrow" style="text-align: center;">
      <p class="accent-script">Well, this is awkward</p>
      <h1>404 — wrong turn</h1>
      <p>
        This page moved away (or never lived here). Happens to the best blocks.
      </p>
      <div class="img-frame" style="margin-block: var(--space-lg); box-shadow: var(--shadow-card);">
        <Image src={homesBridge} alt="Flat vector illustration of Midtown homes, tree-lined streets, and the gold Tower Bridge" width={880} />
      </div>
      <a class="btn btn-primary" href={`${base}/`}>Back home</a>
    </div>
  </section>
</Base>
