---
import Base from '../layouts/Base.astro';
import PageBanner from '../components/PageBanner.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Contact" description="Get in touch with the Marshall–New Era Neighborhood Association.">
  <PageBanner title="Contact us" accent="Say hello" image={`${base}/illustrations/spot-meeting.svg`} position="center 35%" />
  <section class="section">
    <div class="container narrow">
      <div class="card">
        <p>
          📧 <a href="mailto:info@marshallnewera.org">info@marshallnewera.org</a><br />
          🌱 Garden questions: <a href="mailto:garden@marshallnewera.org">garden@marshallnewera.org</a><br />
          📞 916-712-6979<br />
          📮 615 27th Street, Sacramento CA 95816
        </p>
        <p style="margin-bottom: 0;">
          Or just show up: board meetings are the 3rd Monday of every month
          (except December), 6:00 pm at the Society Church building, 2711 B St.
        </p>
      </div>
    </div>
  </section>
</Base>
