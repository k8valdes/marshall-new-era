---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Wave from '../components/Wave.astro';
import EventCard from '../components/EventCard.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const today = new Date();
today.setHours(0, 0, 0, 0);

const events = (await getCollection('events'))
  .filter((e) => e.data.date >= today)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  .slice(0, 3);

const news = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title="Home">
  <section class="hero section-teal on-dark">
    <div class="container hero-inner">
      <div>
        <p class="accent-script">Welcome to the neighborhood!</p>
        <h1>This is our neighborhood.<br />Let's shape it together.</h1>
        <p class="hero-sub">
          We're the Marshall–New Era Neighborhood Association — your neighbors in
          Midtown Sacramento, working (and partying, and gardening) to make this a
          place every resident can enjoy.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary" href={`${base}/join/`}>Become a member — $20/yr</a>
          <a class="btn btn-secondary" href={`${base}/events/`}>See what's happening</a>
        </div>
      </div>
      <img class="hero-badge" src={`${base}/brand/logo-circle-gold.png`} alt="MNENA badge in a gold circle" width="220" height="220" />
    </div>
  </section>
  <Wave color="var(--color-surface-inverse)" />

  <section class="section">
    <div class="container">
      <p class="section-label">Coming up</p>
      <h2>Get out and meet each other</h2>
      <div class="grid-3">
        {events.map((event) => <EventCard event={event} />)}
      </div>
      <p style="margin-top: var(--space-lg);"><a href={`${base}/events/`}>All events →</a></p>
    </div>
  </section>

  <section class="section section-white">
    <div class="container split">
      <div>
        <p class="section-label">Who we are</p>
        <h2>Just neighbors who love it here</h2>
        <p>
          MNENA members are your neighbors. We all live in Sacramento's Midtown
          and are passionate about keeping it wonderful — advocating with the
          City, tracking development, organizing cleanups, and throwing a
          genuinely good holiday party.
        </p>
        <p>
          Only about 3% of the neighborhood are members so far. Renters,
          homeowners, longtimers, brand-new arrivals: you all count, and
          you're all welcome.
        </p>
        <a class="btn btn-primary" href={`${base}/about/`}>More about us</a>
      </div>
      <div>
        <p class="section-label">The garden</p>
        <h2>Our community garden is reborn 🌱</h2>
        <p>
          After two years sitting vacant, we secured a 5-year lease and
          restarted the garden at 26th &amp; B. All 41 plots snapped up fast —
          join the waitlist or become a Friend of the Garden for $20/yr.
        </p>
        <a class="btn btn-secondary" href={`${base}/community-garden/`}>Visit the garden page</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">News</p>
      <h2>Latest from the neighborhood</h2>
      <div class="grid-3">
        {news.map((post) => (
          <article class="card">
            <p class="section-label">{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}</p>
            <h3><a href={`${base}/news/${post.id}/`}>{post.data.title}</a></h3>
            <p>{post.data.excerpt}</p>
          </article>
        ))}
      </div>
      <p style="margin-top: var(--space-lg);"><a href={`${base}/news/`}>All news →</a></p>
    </div>
  </section>

  <section class="section section-teal on-dark newsletter">
    <div class="container narrow" style="text-align:center;">
      <p class="accent-script">Don't miss the fun</p>
      <h2>Get 2–3 emails a month on what's happening</h2>
      <p>
        Event invites, cleanup dates, and neighborhood updates. No spam, no
        selling your address — we literally live next door.
      </p>
      <a class="btn btn-primary" href="mailto:info@marshallnewera.org?subject=Add me to the newsletter">Sign me up</a>
      <p style="margin-top: var(--space-md); font-size: 0.875rem;">
        Also find us on <a href="https://www.instagram.com/marshallnewera/">Instagram</a>&ensp;and&ensp;<a href="https://www.facebook.com/marshallnewera">Facebook</a>.
      </p>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: var(--space-2xl) var(--space-xl);
  }
  .hero-inner {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
  }
  .hero-sub {
    font-size: 1.15rem;
    max-width: 34rem;
  }
  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }
  .hero-badge {
    flex-shrink: 0;
    border-radius: 50%;
  }
  @media (max-width: 800px) {
    .hero-badge { display: none; }
  }
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
  }
  .split {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-2xl);
  }
</style>
