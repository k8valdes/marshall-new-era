---
// The "neighborhood blocks" mosaic from the lawn-sign map — a running brand
// motif. Renders a strip of brand-colored squares; deterministic per seed so
// builds are stable but different placements vary.
interface Props {
  seed?: number;
  columns?: number;
  rows?: number;
  size?: number; // square size in px
  class?: string;
}

const { seed = 1, columns = 14, rows = 2, size = 12, class: className = '' } = Astro.props;

// Brand palette weighted toward greens/teals, with gold/orange pops — like the sign's map.
const palette = ['#5DA145', '#479FB3', '#004447', '#F3CB4A', '#7CD1E8', '#EC8A1F', '#368A59'];

// Small deterministic PRNG (mulberry32) so the mosaic never shifts between builds.
const rand = (() => {
  let a = seed * 2654435761;
  return () => {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
})();

const cells: { x: number; y: number; fill: string }[] = [];
for (let r = 0; r < rows; r++) {
  for (let c = 0; c < columns; c++) {
    if (rand() < 0.28) continue; // gaps keep it airy, like the sign
    cells.push({ x: c, y: r, fill: palette[Math.floor(rand() * palette.length)] });
  }
}
const gap = Math.round(size / 4);
const step = size + gap;
---

<svg
  class={`grid-motif ${className}`}
  width={columns * step - gap}
  height={rows * step - gap}
  viewBox={`0 0 ${columns * step - gap} ${rows * step - gap}`}
  aria-hidden="true"
>
  {cells.map((cell) => (
    <rect x={cell.x * step} y={cell.y * step} width={size} height={size} rx={size / 6} fill={cell.fill} />
  ))}
</svg>

<style>
  .grid-motif {
    display: block;
  }
</style>
