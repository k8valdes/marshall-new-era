---
// Generated on-brand card art for every news post: a seeded flat-vector
// mini-scene (sky, skyline, one motif, chicklet blocks) so the news grid is
// visually cohesive regardless of what imagery a post contains. Deterministic
// per post id — the same post always gets the same card.
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'news'>;
  class?: string;
}

const { post, class: className = '' } = Astro.props;

// mulberry32 — stable across builds
const seedNum = [...post.id].reduce((a, c) => a + c.charCodeAt(0) * 31, 7);
const rand = (() => {
  let a = seedNum * 2654435761;
  return () => {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
})();

// palette rotation: three sky moods (brand variation rule)
const moods = [
  { sky: '#7AB6A4', far: '#35917E', ground: '#5DA145', groundEdge: '#4C8F3D' },
  { sky: '#9CC8BA', far: '#479FB3', ground: '#5DA145', groundEdge: '#4C8F3D' },
  { sky: '#004447', far: '#0B5A56', ground: '#0B4A44', groundEdge: '#01332F' },
];
const mood = moods[Math.floor(rand() * moods.length)];
const dark = mood.sky === '#004447';

// skyline: 6 seeded buildings
const buildings = Array.from({ length: 6 }, (_, i) => {
  const w = 60 + Math.floor(rand() * 50);
  const h = 90 + Math.floor(rand() * 130);
  const x = 20 + i * 125 + Math.floor(rand() * 30);
  return { x, w, h, pediment: rand() > 0.6 };
});

// one hero motif per card
const motifs = ['bridge', 'house', 'tree', 'capitol', 'sprout', 'star'];
const motif = motifs[Math.floor(rand() * motifs.length)];

// chicklet strip
const chickletPalette = ['#5DA145', '#479FB3', '#F3CB4A', '#EC8A1F', '#7CD1E8', '#368A59', '#FBDD9F'];
const chicklets = Array.from({ length: 6 }, () => chickletPalette[Math.floor(rand() * chickletPalette.length)]);

const gold = '#F3CB4A';
const deep = dark ? '#F7ECCC' : '#004447';
---

<div class:list={['img-frame', 'news-art', className]}>
  <svg viewBox="0 0 760 475" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="" preserveAspectRatio="xMidYMid slice">
    <rect width="760" height="475" fill={mood.sky} />
    <g fill="#F7ECCC" opacity={dark ? 0.25 : 1}>
      <ellipse cx={120 + rand() * 80} cy={60 + rand() * 30} rx="52" ry="18" />
      <path d={`M${480 + rand() * 120} 96 a22 22 0 0 1 22 -22 a26 26 0 0 1 48 -7 a20 20 0 0 1 30 19 q0 10 -10 10 h-80 q-10 0 -10 -10 Z`} />
    </g>
    <g fill={mood.far}>
      {buildings.map((b) =>
        b.pediment ? (
          <path d={`M${b.x} 350 v-${b.h} h${b.w * 0.66} l${b.w * 0.17} -22 l${b.w * 0.17} 22 v${b.h} Z`} />
        ) : (
          <rect x={b.x} y={350 - b.h} width={b.w} height={b.h} />
        )
      )}
    </g>
    <rect y="350" width="760" height="125" fill={mood.ground} />
    <rect y="350" width="760" height="10" fill={mood.groundEdge} />

    {motif === 'bridge' && (
      <g transform="translate(300 110)">
        <g fill={gold}>
          <rect x="0" y="0" width="16" height="200" />
          <rect x="44" y="0" width="16" height="200" />
          <rect x="-6" y="-8" width="72" height="14" rx="3" />
          <rect x="-6" y="60" width="72" height="10" />
          <rect x="-6" y="160" width="72" height="10" />
        </g>
        <path d="M-2 70 L62 160 M62 70 L-2 160" stroke={gold} stroke-width="9" />
        <rect x="-140" y="200" width="340" height="14" fill="#E0B93E" />
      </g>
    )}
    {motif === 'house' && (
      <g transform="translate(280 200)">
        <rect x="0" y="40" width="180" height="112" fill={dark ? '#F7ECCC' : '#F7ECCC'} />
        <path d="M-18 40 L198 40 L90 -44 Z" fill={dark ? '#F3CB4A' : '#0B3A38'} />
        <circle cx="90" cy="14" r="14" fill="#7CD1E8" />
        <rect x="24" y="68" width="34" height="42" rx="2" fill="#479FB3" />
        <rect x="122" y="68" width="34" height="42" rx="2" fill="#479FB3" />
        <rect x="72" y="92" width="36" height="60" fill="#EC8A1F" />
      </g>
    )}
    {motif === 'tree' && (
      <g transform="translate(330 160)">
        <rect x="42" y="120" width="16" height="80" fill="#7A4A21" />
        <path d="M50 150 q-70 0 -70 -56 q0 -40 40 -48 q8 -36 48 -36 q40 0 48 36 q40 8 40 48 q0 56 -70 56 Z" fill={dark ? '#5DA145' : '#368A59'} />
        <circle cx="20" cy="60" r="10" fill={gold} />
        <circle cx="84" cy="44" r="8" fill="#EC8A1F" />
      </g>
    )}
    {motif === 'capitol' && (
      <g transform="translate(290 160)">
        <rect x="0" y="110" width="180" height="92" fill="#F7ECCC" />
        <path d="M36 110 v-48 a54 54 0 0 1 108 0 v48 Z" fill="#F7ECCC" />
        <circle cx="90" cy="42" r="9" fill="#F7ECCC" />
        <g fill={mood.far}>
          <rect x="18" y="128" width="14" height="74" /><rect x="48" y="128" width="14" height="74" />
          <rect x="78" y="128" width="14" height="74" /><rect x="108" y="128" width="14" height="74" />
          <rect x="138" y="128" width="14" height="74" />
        </g>
      </g>
    )}
    {motif === 'sprout' && (
      <g transform="translate(310 180)">
        <rect x="0" y="120" width="150" height="52" rx="9" fill={dark ? '#F7ECCC' : '#004447'} />
        <rect x="9" y="108" width="132" height="18" rx="6" fill={dark ? '#E8D9B4' : '#01332F'} />
        <path d="M75 108 c-26 -32 -26 -54 0 -70 c26 16 26 38 0 70 Z" fill="#5DA145" />
        <circle cx="42" cy="70" r="12" fill="#EC8A1F" />
        <circle cx="110" cy="58" r="10" fill={gold} />
      </g>
    )}
    {motif === 'star' && (
      <g transform="translate(380 210)">
        <circle cx="0" cy="0" r="66" fill="#FFFFFF" />
        <path d="M0 -38 l11.7 23.7 26.2 3.8 -19 18.5 4.5 26.1 -23.4 -12.3 -23.4 12.3 4.5 -26.1 -19 -18.5 26.2 -3.8 Z" fill="#EC8A1F" />
      </g>
    )}

    <g>
      {chicklets.map((c, i) => (
        <rect x={30 + i * 70} y="405" width="52" height="34" rx="6" fill={c} />
      ))}
    </g>
  </svg>
</div>

<style>
  .news-art {
    background: var(--color-background-soft);
  }
  .news-art svg {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
