---
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/open-sans';
import '@fontsource-variable/dancing-script';
import '../styles/global.css';
import Wave from '../components/Wave.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Marshall–New Era Neighborhood Association — neighbors making Midtown Sacramento a great place to live.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const nav = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/about/`, label: 'About' },
  { href: `${base}/events/`, label: 'Events' },
  { href: `${base}/news/`, label: 'News' },
  { href: `${base}/community-garden/`, label: 'Garden' },
  { href: `${base}/join/`, label: 'Join Us' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · MNENA</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={`${base}/`}>
          <img src={`${base}/brand/logo-badge.png`} alt="" width="44" height="50" />
          <span class="brand-text">
            <strong>Marshall–New Era</strong>
            <span>Neighborhood Association</span>
          </span>
        </a>
        <nav aria-label="Main">
          <ul class="nav-list">
            {nav.map((item) => (
              <li><a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer on-dark">
      <Wave flip color="var(--color-background)" />
      <div class="container footer-inner">
        <div>
          <img src={`${base}/brand/logo-circle-gold.png`} alt="MNENA badge logo" width="96" height="96" style="border-radius:50%;" />
          <p class="accent-script" style="font-size:1.6rem;">This is our neighborhood.<br />Let's shape it together.</p>
        </div>
        <div>
          <h3>Come say hi</h3>
          <p>
            Monthly meetings — 3rd Monday, 6pm<br />
            Society Church Building, 2711 B St<br />
            Everyone's welcome (there's potluck snacks).
          </p>
        </div>
        <div>
          <h3>Stay in touch</h3>
          <p>
            <a href="mailto:info@marshallnewera.org">info@marshallnewera.org</a><br />
            <a href="https://www.instagram.com/marshallnewera/">Instagram</a>&ensp;·&ensp;<a href="https://www.facebook.com/marshallnewera">Facebook</a><br />
            615 27th Street, Sacramento CA 95816
          </p>
        </div>
      </div>
      <div class="container footer-legal">
        <p>© {new Date().getFullYear()} Marshall–New Era Neighborhood Association · <a href={`${base}/brand/`}>Brand guide</a></p>
      </div>
    </footer>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -999px;
    top: 0;
    background: var(--color-sun-gold);
    color: var(--color-deep-teal);
    padding: var(--space-sm) var(--space-md);
    z-index: 10;
  }
  .skip-link:focus {
    left: 0;
  }
  .site-header {
    background: var(--color-surface-inverse);
    padding-block: var(--space-sm);
    position: sticky;
    top: 0;
    z-index: 5;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .brand-text strong {
    font-family: var(--font-heading);
    color: var(--color-cream);
    font-size: 1.05rem;
  }
  .brand-text span {
    color: var(--color-sky-blue);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .nav-list {
    display: flex;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  .nav-list a {
    color: var(--color-cream);
    text-decoration: none;
    font-weight: 600;
    padding: 0.35rem 0.6rem;
    border-radius: var(--radius-sm);
  }
  .nav-list a:hover,
  .nav-list a[aria-current='page'] {
    background: rgba(247, 236, 204, 0.14);
    color: var(--color-sun-gold);
  }
  .site-footer {
    background: var(--color-surface-inverse);
    margin-top: var(--space-2xl);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-xl);
    padding-block: var(--space-xl);
  }
  .footer-legal {
    border-top: 1px solid rgba(247, 236, 204, 0.25);
    padding-block: var(--space-md);
    font-size: 0.875rem;
  }
</style>
